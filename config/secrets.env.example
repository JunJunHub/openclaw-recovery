# OpenClaw 敏感配置
# 复制此文件为 secrets.env 并填入真实值

# ============================================
# 模型 API Keys
# ============================================

# SiliconFlow API Key (必需)
# 获取地址: https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=sk-your-siliconflow-key

# 百度千帆 API Key (必需)
# 获取地址: https://console.bce.baidu.com/qianfan/ais/console/onlineService
BAIDU_QIANFAN_API_KEY=bce-v3/your-baidu-key

# ============================================
# 飞书配置 (可选)
# ============================================

# 飞书应用 ID
# 获取地址: https://open.feishu.cn/app
FEISHU_APP_ID=cli_your-app-id

# 飞书应用密钥
FEISHU_APP_SECRET=your-app-secret

# ============================================
# Gateway 配置
# ============================================

# Gateway 认证令牌 (自定义，建议随机生成)
# 可使用: openssl rand -hex 24
GATEWAY_TOKEN=your-secure-token-here

# ============================================
# 其他配置 (可选)
# ============================================

# Serper API Key (用于网络搜索)
# 获取地址: https://serper.dev/api-key
# SERPER_API_KEY=your-serper-key
